# 第一阶段：构建环境，安装依赖到虚拟环境
FROM docker.yogu.team/infra/python:3.12 AS builder

# 设置工作目录
WORKDIR /app

COPY pyproject.toml .
COPY uv.lock .

ENV UV_HTTP_TIMEOUT=300

RUN uv sync --no-install-project

# 复制源代码
COPY src/ ./src/

RUN uv sync

# 第二阶段：轻量运行环境
FROM docker.yogu.team/infra/python:3.12 AS runner

# 设置工作目录
WORKDIR /app

# 从builder阶段复制所有内容
COPY --from=builder /app /app

# 启动命令（使用 Celery worker）
CMD ["uv", "run", "celery", "-A", "src.app.tasks.worker", "worker", "--loglevel=info", "--concurrency=3"]
